# ==========================================================================
# TVapp 環境変数サンプル（MVP: Cloudflare Workers + Firebase・ほぼ $0）
#
# 使い方:
#   1) このファイルを `.env.local` にコピー
#   2) 下の Firebase の値を自分のプロジェクトのもので埋める
#   3) `npm run dev`(ローカル) / `npm run cf:build`(Cloudflare向けビルド)
#
# 注意: NEXT_PUBLIC_* はビルド時にクライアントへ埋め込まれる。
#       Cloudflare へデプロイする際は `cf:build` を実行する環境に必ず設定すること。
# ==========================================================================

# --- Firebase クライアント設定（MVP 必須。Firebase コンソール > プロジェクトの設定 > 全般 > SDK 構成）---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""            # 例: your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""         # 例: your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- 認証トークンの localStorage キー名（MVP 必須。任意の文字列。例: IdToken）---
NEXT_PUBLIC_IDTOKEN_NAME="IdToken"

# --- 任意: ローカル確認用の認証バイパス(開発のみ) ---
# Firebase 設定なしで TVER のブラウズ/再生を確認したいときだけ 1 にする。
# 本番(NODE_ENV=production)では二重ガードで絶対に無効。コミット環境には置かないこと。
# NEXT_PUBLIC_DEV_BYPASS_AUTH="1"

# --- 任意: ライブ配信(/stream)機能を使う場合のみ ---
# NEXT_PUBLIC_STREAM_PASSWORD=""
# NEXT_PUBLIC_JP_STREAMING_M3U_URL=""

# --- 任意: 独自JWT(verify-token 等)を使う場合のみ（サーバー側・Cloudflare では Worker secret 推奨）---
# JWT_SECRET_KEY=""
# JWT_EXPIRATION_TIME="7d"

# ==========================================================================
# 段階2(お気に入り/視聴履歴/プロフィール/管理)を有効化するときに追加:
#   Firestore クライアント方式へ移行するため firebase-admin は不要になる予定。
#   Cosmos DB / Azure Functions は廃止。以下は「現行コード互換」の参考。
# ==========================================================================
# FIREBASE_ADMIN_SDK_JSON=''            # サービスアカウントJSON(1行)
# COSMOSDB_ENDPOINT=""                  # ※MVP/新設計では使用しない
# COSMOSDB_KEY=""
